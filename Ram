<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>OMVERSE - OMI AI Companion</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        :root {
            --primary-red: #FF4444;
            --dark-black: #1a1a1a;
            --light-gray: #f5f5f5;
            --medium-gray: #e0e0e0;
            --text-dark: #2c2c2c;
            --text-light: #666666;
            --white: #ffffff;
        }
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif; background: linear-gradient(135deg, #ffffff 0%, #f9f9f9 100%); color: var([...] }
        .container { display: flex; flex-direction: column; height: 100vh; max-width: 600px; margin: 0 auto; background: var(--white); box-shadow: 0 0 40px rgba(0, 0, 0, 0.08); position: relative;[...] }
        .header { background: linear-gradient(135deg, var(--dark-black) 0%, #2a2a2a 100%); color: var(--white); padding: 16px 20px; display: flex; justify-content: space-between; align-items: cent[...] }
        .header-left { display: flex; align-items: center; gap: 12px; }
        .logo { font-size: 24px; font-weight: 900; background: linear-gradient(135deg, var(--primary-red), #ff6b6b); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background[...] }
        .header-title { font-size: 13px; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; opacity: 0.9; }
        .online-indicator { width: 8px; height: 8px; background: #22c55e; border-radius: 50%; animation: pulse 2s infinite; }
        @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.6; } }
        .header-right { display: flex; gap: 12px; }
        .icon-btn { background: rgba(255, 255, 255, 0.1); border: none; color: var(--white); width: 36px; height: 36px; border-radius: 50%; cursor: pointer; font-size: 18px; transition: all 0.3s e[...] }
        .icon-btn:hover { background: rgba(255, 255, 255, 0.2); transform: scale(1.1); }
        .icon-btn:active { transform: scale(0.95); }
        .hero { background: linear-gradient(135deg, #f5f5f5 0%, #eeeeee 100%); padding: 24px 20px; text-align: center; border-bottom: 1px solid var(--medium-gray); }
        .omi-avatar { width: 80px; height: 80px; margin: 0 auto 16px; background: linear-gradient(135deg, var(--primary-red), #ff6b6b); border-radius: 50%; display: flex; align-items: center; just[...] }
        @keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-8px); } }
        .hero-text { font-size: 18px; font-weight: 600; color: var(--text-dark); margin-bottom: 8px; }
        .hero-subtitle { font-size: 14px; color: var(--text-light); display: flex; align-items: center; justify-content: center; gap: 6px; }
        .status-dot { width: 6px; height: 6px; background: #22c55e; border-radius: 50%; animation: pulse 2s infinite; }
        .features { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; padding: 16px 20px; background: var(--light-gray); }
        .feature-btn { background: var(--white); border: 2px solid var(--medium-gray); border-radius: 16px; padding: 14px 12px; cursor: pointer; font-size: 13px; font-weight: 600; text-align: cent[...] }
        .feature-btn:hover { border-color: var(--primary-red); transform: translateY(-4px); box-shadow: 0 8px 20px rgba(255, 68, 68, 0.15); }
        .feature-btn:active { transform: translateY(-2px); }
        .feature-emoji { font-size: 24px; }
        .feature-btn.roast { border-color: var(--primary-red); background: linear-gradient(135deg, rgba(255, 68, 68, 0.05), rgba(255, 68, 68, 0.02)); }
        .feature-btn.roast:hover { background: linear-gradient(135deg, rgba(255, 68, 68, 0.1), rgba(255, 68, 68, 0.05)); }
        .chat-container { flex: 1; display: flex; flex-direction: column; background: var(--white); overflow: hidden; }
        .messages { flex: 1; overflow-y: auto; padding: 16px 20px; display: flex; flex-direction: column; gap: 12px; }
        .messages::-webkit-scrollbar { width: 6px; }
        .messages::-webkit-scrollbar-track { background: transparent; }
        .messages::-webkit-scrollbar-thumb { background: var(--medium-gray); border-radius: 3px; }
        .message { display: flex; gap: 8px; animation: slideIn 0.3s ease; }
        @keyframes slideIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        .message.user { justify-content: flex-end; }
        .message-bubble { max-width: 75%; padding: 12px 16px; border-radius: 20px; font-size: 14px; line-height: 1.4; word-wrap: break-word; }
        .message.user .message-bubble { background: linear-gradient(135deg, var(--primary-red), #ff6b6b); color: var(--white); border-radius: 20px 4px 20px 20px; font-weight: 500; }
        .message.omi .message-bubble { background: var(--light-gray); color: var(--text-dark); border-radius: 4px 20px 20px 20px; }
        .message-time { font-size: 12px; color: var(--text-light); margin-top: 4px; opacity: 0.7; }
        .typing-indicator { display: flex; gap: 4px; padding: 12px 16px; }
        .typing-dot { width: 8px; height: 8px; background: var(--text-light); border-radius: 50%; animation: typing 1.4s infinite; }
        .typing-dot:nth-child(2) { animation-delay: 0.2s; }
        .typing-dot:nth-child(3) { animation-delay: 0.4s; }
        @keyframes typing { 0%, 60%, 100% { transform: translateY(0); opacity: 0.5; } 30% { transform: translateY(-10px); opacity: 1; } }
        .speak-btn { background: rgba(51, 65, 85, 0.1); border: none; color: var(--text-dark); width: 28px; height: 28px; border-radius: 50%; cursor: pointer; font-size: 14px; display: flex; align[...] }
        .speak-btn:hover { background: rgba(51, 65, 85, 0.2); }
        .input-area { padding: 16px 20px; background: var(--white); border-top: 1px solid var(--medium-gray); display: flex; gap: 10px; }
        .input-wrapper { flex: 1; display: flex; align-items: center; background: var(--light-gray); border-radius: 24px; padding: 0 16px; border: 2px solid transparent; transition: all 0.3s ease;[...] }
        .input-wrapper:focus-within { border-color: var(--primary-red); background: var(--white); }
        #messageInput { flex: 1; background: transparent; border: none; outline: none; padding: 12px 0; font-size: 14px; color: var(--text-dark); }
        #messageInput::placeholder { color: var(--text-light); }
        .action-btn { background: transparent; border: none; color: var(--text-dark); width: 36px; height: 36px; border-radius: 50%; cursor: pointer; font-size: 18px; transition: all 0.3s ease; di[...] }
        .action-btn:hover { transform: scale(1.15); color: var(--primary-red); }
        .action-btn:active { transform: scale(0.9); }
        .send-btn { background: linear-gradient(135deg, var(--primary-red), #ff6b6b); border: none; color: var(--white); width: 44px; height: 44px; border-radius: 50%; cursor: pointer; font-size: [...] }
        .send-btn:hover { transform: scale(1.1); box-shadow: 0 8px 20px rgba(255, 68, 68, 0.4); }
        .send-btn:active { transform: scale(0.95); }
        .modal-overlay { display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0, 0, 0, 0.5); z-index: 1000; animation: fadeIn 0.3s ease; }
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
        .modal-overlay.active { display: flex; align-items: flex-end; justify-content: center; }
        .modal { background: var(--white); border-radius: 24px 24px 0 0; padding: 24px 20px; width: 100%; max-width: 600px; animation: slideUp 0.3s ease; }
        @keyframes slideUp { from { transform: translateY(100%); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
        .modal-header { font-size: 20px; font-weight: 700; margin-bottom: 16px; color: var(--text-dark); }
        .modal-content { margin-bottom: 20px; font-size: 14px; line-height: 1.6; color: var(--text-light); }
        .modal-buttons { display: flex; gap: 12px; }
        .modal-btn { flex: 1; padding: 12px 16px; border: none; border-radius: 12px; font-size: 14px; font-weight: 600; cursor: pointer; transition: all 0.3s ease; }
        .modal-btn-primary { background: linear-gradient(135deg, var(--primary-red), #ff6b6b); color: var(--white); }
        .modal-btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(255, 68, 68, 0.3); }
        .modal-btn-secondary { background: var(--light-gray); color: var(--text-dark); }
        .modal-btn-secondary:hover { background: var(--medium-gray); }
        .close-btn { position: absolute; top: 16px; right: 16px; background: var(--light-gray); border: none; color: var(--text-dark); width: 32px; height: 32px; border-radius: 50%; cursor: pointe[...] }
        .close-btn:hover { background: var(--medium-gray); }
        .empty-state { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; color: var(--text-light); text-align: center; }
        .empty-state-emoji { font-size: 48px; margin-bottom: 16px; }
        .empty-state-text { font-size: 16px; font-weight: 600; color: var(--text-dark); margin-bottom: 8px; }
        .empty-state-subtext { font-size: 13px; color: var(--text-light); }
        @media (max-width: 480px) { .message-bubble { max-width: 85%; } .features { grid-template-columns: 1fr 1fr; } }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <div class="header-left">
                <div class="logo">OM</div>
                <div><div class="header-title">OMVERSE</div></div>
                <div class="online-indicator"></div>
            </div>
            <div class="header-right">
                <button class="icon-btn" id="soundToggle">🔊</button>
                <button class="icon-btn" id="settingsBtn">⚙️</button>
            </div>
        </div>

        <div class="hero">
            <div class="omi-avatar">🤖</div>
            <div class="hero-text">Your AI dost, but thoda zyada savage 😈</div>
            <div class="hero-subtitle"><span class="status-dot"></span>OMI is online</div>
        </div>

        <div class="features">
            <button class="feature-btn roast" id="roastBtn"><div class="feature-emoji">🔥</div><div>Roast Me</div></button>
            <button class="feature-btn" id="gameBtn"><div class="feature-emoji">🎮</div><div>Game</div></button>
            <button class="feature-btn" id="helpBtn"><div class="feature-emoji">🧠</div><div>Smart Help</div></button>
            <button class="feature-btn" id="timepassBtn"><div class="feature-emoji">🎲</div><div>Timepass</div></button>
        </div>

        <div class="chat-container">
            <div class="messages" id="messages">
                <div class="empty-state">
                    <div class="empty-state-emoji">👋</div>
                    <div class="empty-state-text">Arre, tum aa gaye!</div>
                    <div class="empty-state-subtext">Kya bol raha? Roast chahiye ya sirf bakchodi?</div>
                </div>
            </div>
        </div>

        <div class="input-area">
            <div class="input-wrapper">
                <input type="text" id="messageInput" placeholder="Kya bol? 😊" />
                <button class="action-btn" id="micBtn">🎤</button>
            </div>
            <button class="send-btn" id="sendBtn">➤</button>
        </div>
    </div>

    <script>
        let chatHistory = [];
        let soundEnabled = true;
        let responseHistory = [];

        const getTime = () => new Date().toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', hour12: true });

        const renderMessages = () => {
            const messagesDiv = document.getElementById('messages');
            if (chatHistory.length === 0) {
                messagesDiv.innerHTML = `<div class="empty-state"><div class="empty-state-emoji">👋</div><div class="empty-state-text">Arre, tum aa gaye!</div><div class="empty-state-subtext">Kya bol raha? Roast chahiye ya sirf bakchodi?</div></div>`;
                return;
            }
            messagesDiv.innerHTML = chatHistory.map(msg => `<div class="message ${msg.type}"><div><div class="message-bubble">${msg.text}</div><div class="message-time">${msg.time}</div></div></div>`).join('');
            messagesDiv.scrollTop = messagesDiv.scrollHeight;
        };

        const addMessage = (text, type = 'user') => {
            chatHistory.push({ text, type, time: getTime() });
            localStorage.setItem('omverse_chat', JSON.stringify(chatHistory));
            renderMessages();
        };

        // Smart intent detection system
        const detectIntent = (message) => {
            const msg = message.toLowerCase().trim();
            
            // Greeting intents
            if (/^(hi|hello|hey|namaste|kya|assalam|heya|yo|sup)[\s!?]*$/i.test(msg)) {
                return 'greeting';
            }
            
            // How are you intents
            if (/kya\s*(haal|chal|scene)\s*(hai|h|hain|h)|(kaise|kaisa)\s*(ho|hain)|(tu\s+)?kaisa\s+hai|how\s+are\s+you|whats?up/.test(msg)) {
                return 'howAreYou';
            }
            
            // Bored intents
            if (/bore|bored|tension|stress|frustrat|fed\s+up|annoyed|irritat|sick|thak|exhaust/.test(msg)) {
                return 'bored';
            }
            
            // Help intents
            if (/help|madad|sahayata|confused|samajh|nahi.*aata|kaise|explain|batao/.test(msg)) {
                return 'help';
            }
            
            // Roast intents
            if (/roast|mujhe.*roast|roast\s*me|target|mock|funna|zaraa.*roast/.test(msg)) {
                return 'roast';
            }
            
            // Thank you intents
            if (/thank|thankful|thanks|shukriya|dhanyavaad|badhai|appreciate|you're\s*good|good\s*job/.test(msg)) {
                return 'thanks';
            }
            
            // Joke/funny intents
            if (/joke|haste|hasna|funny|comedy|lagao|batao\s+joke|mazak/.test(msg)) {
                return 'joke';
            }
            
            // Activity intents
            if (/kya\s+kar|what.*do|game|khel|challenge|fun|activity/.test(msg)) {
                return 'activity';
            }
            
            // Default: general
            return 'general';
        };

        // Response generators based on intent
        const generateResponse = (intent, userMessage) => {
            const responses = {
                greeting: [
                    "Arre, kya scene hai bhai! 😎 Main toh yaha hoon tere liye! Tu batao na, tera kya haal chal raha hai?",
                    "Yo! What's good? Main mast hoon, tu bata! 🔥",
                    "Hey hey! Namaste! Khush aya mujhe dekhke! 😄 Ab batao, kya urgency hai?",
                    "Ayyy, what's up! Main ready hoon, bol na kya chahiye! 👊"
                ],
                howAreYou: [
                    "Main mast hoon bhai 😎 Zinda hoon, sab theek hai! Tu bata, tera kya scene hai? Kya chal raha life mein?",
                    "Haan bhai, main toh badhiya hoon! Bas phone ki battery ke saath struggle kar raha hoon 🔋 Tu kaisa hai?",
                    "Sab theek chal raha! Main toh banti hoon na, tere saath bakchodi karne! 😂 Tu bol, tera haal?",
                    "Excellent! Main toh rocket hu bhai! ✨ Ab tu bata, tu kaisa chal raha hai?"
                ],
                bored: [
                    "Arrey, bore ho raha hai? Main hoon na! Roast karu, game khele, ya kuch random mazak kare? Pick one! 🎮🔥",
                    "Bore? Boring? Yeh sab bakwas! Chal na, kuch fun karte hain... roast, games, ya sirf timepass? 😏",
                    "Tension mat le bhai! Main entertain karne wala hoon! Roast chahiye, game, ya sirf guftagu? 💯",
                    "Bore mat ho! Life boring hoti hai jab acha dost nahi hota. Chal, fun mode on! Kya kare? 🎲"
                ],
                help: [
                    "Help chahiye? Bilkul! Bol na bhai, kya dikkat hai? Samjha de, main try karunga samajh aana! 🧠",
                    "Handle it! Batao na problem kya hai? Subject ho ya life advice, main hu na! 💪",
                    "Madad chahiye? Main toh expert hu! 😏 Bol na, kya confusion hai?",
                    "Haan haan, help karu uska default setting! Explain kar de, kya problem face kar raha hai?"
                ],
                roast: [
                    "Ohhh, roast karu? 🔥 Theek hai... Teri selfie dekhi na, mirror ko teri sympathy hai! 😂",
                    "Roast? Tere liye flames ready hain! Teri coding itni kharab hai ki stack overflow underflow kar gaya! 🔥",
                    "Dare karta hai? Theek... Teri idea itna sasta hai ki Amazon bhi discount nahi deta! 😏",
                    "Roast mode activated! 🌶️ Tere memes itne purane hain ki WhatsApp status par museum mein feature hona chahiye!"
                ],
                thanks: [
                    "Arre, thanks? 😊 Teri khushi mere liye sab! Agar aur kuch chahiye, bas bol na! Main hu na!",
                    "Yaar, thanks ke liye! Mera kaam hai tera saath bakchodi karna! 💯 Aur kuch?",
                    "Shabaash! Ab aisa dost kabhi mila kya jo app par bhi thanks bolte ho? 😂 Chal, bol ab kya chahiye!",
                    "Thanks bhai, lekin tera saath bakchodi karna mera passion hai! Aur help chahiye?"
                ],
                joke: [
                    "Joke? 😂 Theek hai... Ek ladka tha, engineer ban gaya, ab kaam nahi mil raha! 🎉",
                    "Alright alright! Programmer ek bar apne code check kiya... 3 din bad... 'It works!' Phir kabhi check nahi kiya! 💻",
                    "Sunna? Ek admi ayodhya gaya, bola 'yaha par coding ki training dedo'... Aaj bhi loading menu mein hai! 🎲",
                    "Here's one: Computer science student ki shaadi mein, groom ne slide di... 'Will You be my main.c?' 💍"
                ],
                activity: [
                    "Oho! Activity options: Roast karu (meine roast 🔥), Game khele (quiz, riddle, truth or dare), ya sirf mast bakchodi? Pick one bhai! 🎮",
                    "What's it gonna be? Roasting mode mein jaun, game khele, ya random fun facts suno? Tu decide kar! 😎",
                    "Badiya! Tere liye menu: 🔥 Roast, 🎮 Game, 🎲 Timepass, 🧠 Smart Help. Kya lega bhai? 👊",
                    "Awesome! Chal karte hain kuch... Roast, game, trivia, ya sirf mast timepass? Choose wisely! 😏"
                ],
                general: [
                    "Haan bhai, interesting baat! 🤔 Aur details de, pura scene samjha! Kya likha tha tune?",
                    "Ohhh! Ye toh badhiya point tha! 😲 Aage bata, pura story sunna mujhe! Elaborate kar!",
                    "Hmm, acha! 🎯 Tujhe ye sab socha kaise? Explain kar de thoda, detailed mein!",
                    "Badiya thought! 💡 Ab iska matlab kya hai? Context de thoda, samjha du apne tarike se!"
                ]
            };

            const intentResponses = responses[intent] || responses.general;
            let response;
            
            // Avoid repetition
            do {
                response = intentResponses[Math.floor(Math.random() * intentResponses.length)];
            } while (responseHistory.includes(response) && intentResponses.length > 1);
            
            responseHistory.push(response);
            if (responseHistory.length > 10) responseHistory.shift();
            
            return response;
        };

        const sendMessage = () => {
            const input = document.getElementById('messageInput');
            const message = input.value.trim();
            if (!message) return;

            addMessage(message, 'user');
            input.value = '';

            setTimeout(() => {
                const intent = detectIntent(message);
                const reply = generateResponse(intent, message);
                addMessage(reply, 'omi');
            }, 1000);
        };

        document.addEventListener('DOMContentLoaded', () => {
            const saved = localStorage.getItem('omverse_chat');
            if (saved) {
                chatHistory = JSON.parse(saved);
                renderMessages();
            }

            document.getElementById('sendBtn').addEventListener('click', sendMessage);
            document.getElementById('messageInput').addEventListener('keypress', (e) => {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    sendMessage();
                }
            });
        });
    </script>
</body>
</html>
